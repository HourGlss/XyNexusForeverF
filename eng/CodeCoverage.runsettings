<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura,json</Format>
          <ExcludeByFile>**/Migrations/**/*.cs,**/*.Designer.cs,**/*.g.cs,**/obj/**/*.cs</ExcludeByFile>
          <Exclude>[*.Tests]*,[*.Test]*</Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
