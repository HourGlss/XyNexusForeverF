root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cs,csx}]
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion
dotnet_style_qualification_for_event = false:suggestion
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_property = false:suggestion

# Advisory complexity/maintainability rules. The custom report is the source of
# truth for scoring; these keep IDE/build diagnostics aligned without blocking.
dotnet_code_quality.CA1502.threshold = 20
dotnet_code_quality.CA1505.threshold = 80
dotnet_code_quality.CA1506.threshold = 20
dotnet_diagnostic.CA1502.severity = suggestion
dotnet_diagnostic.CA1505.severity = suggestion
dotnet_diagnostic.CA1506.severity = suggestion
dotnet_diagnostic.CA1822.severity = suggestion
dotnet_diagnostic.CA1852.severity = suggestion

[*.{yml,yaml,json,xml,props,targets,csproj,sln,md,sh,ps1}]
indent_size = 2

[*.sln]
indent_style = tab
